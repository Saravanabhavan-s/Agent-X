# Agent X — LLM provider configuration
# Uncomment ONE provider block. Ollama requires no API key.

# ── Local default (Ollama + Qwen) ──────────────────────────────
AGENTX_LLM_PROVIDER=ollama
AGENTX_LLM_MODEL=qwen3:8b
AGENTX_LLM_BASE_URL=http://localhost:11434

# ── Anthropic ──────────────────────────────────────────────────
# AGENTX_LLM_PROVIDER=anthropic
# AGENTX_LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI ─────────────────────────────────────────────────────
# AGENTX_LLM_PROVIDER=openai
# AGENTX_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# ── OpenRouter (any model) ─────────────────────────────────────
# AGENTX_LLM_PROVIDER=openrouter
# AGENTX_LLM_MODEL=meta-llama/llama-3-70b-instruct
# OPENROUTER_API_KEY=sk-or-...

# ── Optional tuning ────────────────────────────────────────────
# AGENTX_LLM_TEMPERATURE=0.2
# AGENTX_LLM_MAX_TOKENS=4096

# ── Repository auth ────────────────────────────────────────────
# AGENTX_GITHUB_TOKEN=ghp_...
# AGENTX_GITLAB_TOKEN=glpat-...
# AGENTX_BITBUCKET_TOKEN=...
# AGENTX_SSH_KEY_PATH=~/.ssh/id_ed25519

# ── Workspace storage ──────────────────────────────────────────
# AGENTX_WORKSPACE_ROOT=./workspaces
